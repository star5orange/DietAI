# ========================================
# DietAI Beta 版环境变量配置
# ========================================
# 请复制此文件为 .env 并填写实际值

# ========================================
# AI 模型 API 密钥（必填其一）
# ========================================
# OpenAI API key (optional, legacy fallback)
OPENAI_API_KEY=

# Anthropic Claude API 密钥（可选）
ANTHROPIC_API_KEY=

# 阿里通义千问 API 密钥（可选）
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE=

# Groq API 密钥（可选）
GROQ_API_KEY=

# DeepSeek API
DEEPSEEK_API_KEY=sk-5e49480ae8154e028bcbfd5576c6aa48
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
ANALYSIS_MODEL_PROVIDER=deepseek
ANALYSIS_MODEL=deepseek-v4-flash

# Vision model for food image analysis. DeepSeek chat models do not replace this.
VISION_MODEL_PROVIDER=qwen
VISION_MODEL=qwen-vl-max

# ========================================
# 基础设施配置（Docker 环境已预配置）
# ========================================
# Redis 密码
REDIS_PASSWORD=123456

# ========================================
# 向量存储配置
# ========================================
VECTOR_STORE_PATH=agents/VectorStore
VECTOR_COLLECTION_NAME=nutrition_collection

# ========================================
# 其他 API（可选）
# ========================================
YUANJING_API_KEY=
YUNAJING_SECRET_KEY=

# ========================================
# DietAI Beta 版环境变量配置
# ========================================
# 请复制此文件为 .env 并填写实际值

# ========================================
# AI 模型 API 密钥（必填其一）
# ========================================
# OpenAI API key (optional, legacy fallback)
OPENAI_API_KEY=

# Anthropic Claude API 密钥（可选）
ANTHROPIC_API_KEY=

# 阿里通义千问 API 密钥（可选）
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE=

# Groq API 密钥（可选）
GROQ_API_KEY=

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
ANALYSIS_MODEL_PROVIDER=deepseek
ANALYSIS_MODEL=deepseek-v4-flash

# Vision model for food image analysis. DeepSeek chat models do not replace this.
VISION_MODEL_PROVIDER=qwen
VISION_MODEL=qwen-vl-max

# ========================================
# 安全配置
# ========================================
# JWT 密钥（生产环境必须设置，不可使用默认值）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
DIETAI_JWT_SECRET_KEY=

# 数据库字段加密密钥（AES-256-GCM，生产环境必须设置）
# 生成方式: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
DIETAI_FIELD_ENCRYPTION_KEY=

# CORS 允许的源（生产环境必须设置，不允许使用 *）
# 多个域名用逗号分隔，例如: https://yourdomain.com,https://app.yourdomain.com
DIETAI_CORS_ORIGINS=

# 允许的主机名（生产环境必须设置，防止 Host 头攻击）
# 多个域名用逗号分隔，例如: yourdomain.com,api.yourdomain.com
DIETAI_ALLOWED_HOSTS=

# ========================================
# 基础设施配置（Docker 环境已预配置）
# ========================================
# Redis 密码
REDIS_PASSWORD=123456

# ========================================
# 向量存储配置
# ========================================
VECTOR_STORE_PATH=agents/VectorStore
VECTOR_COLLECTION_NAME=nutrition_collection

# ========================================
# 其他 API（可选）
# ========================================
YUANJING_API_KEY=
YUNAJING_SECRET_KEY=
